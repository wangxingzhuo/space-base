.header {
  --avatar-size: 32px;
  --avatar-bg-color: #37abe7;
  display: flex;
  box-sizing: border-box;
  padding: 8px 16px;
  justify-content: space-between;
  align-items: center;
  height: 48px;
  position: sticky;
  top: 0;
  z-index: 10000;
  background-color: var(--primary-bg-color);

  .user {
    display: flex;
    align-items: center;
  }

  .nick-name {
    margin-left: 4px;
    color: #fff;
  }

  .btn-add {
    border-radius: 24px;
    width: 24px;
    height: 24px;
    font-size: 18px;
    font-weight: bold;
    line-height: 24px;
    color: #fff;
    background-color: #37abe7;
  }
}

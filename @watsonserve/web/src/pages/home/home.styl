.home.pc
  display flex
  flex-direction column
  height 100vh

  .home-header
    display flex
    width 100%
    height 100px
    align-items center

    h1.app-name
      padding 0 20px
      height 100%
      white-space nowrap
      line-height 100px

    .addr-bar
      display flex
      width 100%
      height 40px
      line-height 40px

      .label
        margin-right 10px
        white-space nowrap

      input.addr
        width 100%

  .dir-wrapper
    display flex
    width 100%
    height 100%
    overflow hidden
    background-color #ddd

    ol.every-lev
      display flex
      flex 0 1 auto
      flex-direction row-reverse
      overflow auto hidden
      user-select none

      li.dir-detail
        flex 1 0 auto
        padding-right 4px
        height 100%
        max-width 16em
        min-width 8em

        &:first-child
          padding-right 0

    .meta
      flex 1 0 20%
      min-width 200px
      background-color #f3f3f3

:root {
  --page-bg: #222;
  --nick-name-color: #ccc;
  --msg-pop-bg: rgba(255, 255, 255, 0.125);
  --sys-msg-color: #aaa;
  --msg-text-color: #eee;
}

@keyframes ring
  0%
    transform rotate(0deg)
  50%
    transform rotate(180deg)
  100%
    transform rotate(360deg)

.chat
  display flex
  box-sizing border-box
  height 100vh
  flex-direction column
  overflow hidden
  background var(--page-bg)

  header.header
    border-bottom 0.5px solid #888
    width 100%
    height 48px

  footer.footer
    display flex
    box-sizing border-box
    padding 8px 16px calc(16px + env(safe-area-inset-bottom))
    width 100%
    height calc(56px + env(safe-area-inset-bottom))
    justify-content space-between
    background rgba(255, 255, 255, 0.125)

    input.msg-editor
      margin-right 8px
      box-sizing border-box
      border 0
      border-radius 4px
      padding 8px
      width 100%
      height 32px
      outline none
      color var(--msg-text-color)
      font-size 16px
      line-height 16px
      background rgba(255, 255, 255, 0.125)

    button.msg-send
      height 32px

  ul.msg-list
    margin 0
    padding 0 16px 32px
    height 100%
    list-style none
    overflow auto

    li.msg-center, li.msg-left, li.msg-right
      margin-top 16px

    li.msg-center
      margin 24px 0
      padding 0 24px
      text-align center
      font-size 12px

      img.avatar, .nick-name, .msg-sending
        display none

      .msg-content
        color var(--sys-msg-color)

    li.msg-left, li.msg-right
      display flex

      img.avatar
        border 1px solid #555
        border-radius 4px
        width 40px
        height 40px
        flex 40px 0 0

      .msg-entry
        display flex
        flex-direction column
        margin 0 12px
        max-width calc(100% - 104px)

        .nick-name
          display block
          margin-bottom 4px
          height 18px
          color var(--nick-name-color)
          font-size 12px
          line-height 18px

        .msg-content
          box-sizing border-box
          border-radius 4px
          padding 8px
          font-size 14px
          background-color var(--msg-pop-bg)

    li.msg-right
      flex-direction row-reverse

      .msg-entry
        align-items flex-end

      i.msg-sending, i.msg-failed
        display block
        margin-top 32px
        border-radius 16px
        width 16px
        height 16px
        text-align center
        font-style normal

      i.msg-sending
        animation ring 1s linear infinite
        background radial-gradient(circle at center, var(--page-bg) 20%, #0000 100%),
          conic-gradient(var(--page-bg) 0%, #fff 100%)

      i.msg-failed
        background #f00

        &::after
          content '!'
          display block
          width 16px
          height 16px
          font-size 12px
          font-weight bold
          line-height 16px
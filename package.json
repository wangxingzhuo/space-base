{
  "name": "space-view",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "@watsonserve/*"
  ],
  "scripts": {
    "utils": "pnpm --filter @watsonserve/asm build && pnpm --filter @watsonserve/utils build",
    "audio": "pnpm --filter @watsonserve/audioplayer build",
    "ui": "pnpm --filter @watsonserve/ui build",
    "connector": "pnpm --filter @watsonserve/connector build",
    "web": "pnpm workspace @watsonserve/web build",
    "resources": "pnpm workspace @watsonserve/resources build",
    "elec": "pnpm workspace @watsonserve/electron build",
    "build": "pnpm utils && pnpm audio && pnpm web && pnpm elec",
    "package": "pnpm build && ./pack.sh",
    "buildweb": "pnpm web && rm -rf ./dist/views && mv ./@watsonserve/web/build ./dist/views",
    "webdev": "pnpm run --filter @watsonserve/web start",
    "dev": "pnpm workspace @watsonserve/electron dev",
    "resource": "pnpm workspace @watsonserve/resources build",
    "stock-loader": "pnpm run --filter @watsonserve/stock-base build",
    "stock-build": "pnpm run --filter @watsonserve/stock-node build",
    "stock-dev": "pnpm run --filter @watsonserve/stock-node srv"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "@rsbuild/plugin-svgr": "^1.2.2",
    "@types/node": "^25.8.0",
    "tsx": "^4.21.0"
  },
  "packageManager": "pnpm@10.33.0"
}
